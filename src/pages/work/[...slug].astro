---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<main class="wrapper">
		<a class="back-link" href="/work/">← work</a>

		<header>
			<p class="prompt"><span class="ps1">~/hengxu $</span> cat projects/{entry.data.title.toLowerCase().replace(/\s+/g, '-')}.md<span class="cursor"></span></p>
			<div class="meta">
				<h1 class="title">{entry.data.title}</h1>
				<p class="description">{entry.data.description}</p>
				<div class="tags">
					{entry.data.tags.map((t) => <span class="tag">{t}</span>)}
				</div>
				{(entry.data.url || entry.data.github) && (
					<div class="project-links">
						{entry.data.url && (
							<a href={entry.data.url} target="_blank" rel="noopener noreferrer" class="proj-link proj-link--primary">
								live site ↗
							</a>
						)}
						{entry.data.github && (
							<a href={entry.data.github} target="_blank" rel="noopener noreferrer" class="proj-link proj-link--outline">
								github ↗
							</a>
						)}
					</div>
				)}
			</div>
		</header>

		<div class="content">
			{entry.data.img && (
				<img class="hero-img" src={entry.data.img} alt={entry.data.img_alt || ''} />
			)}
			{entry.data.images && entry.data.images.length > 0 && (
				<div class="image-grid">
					{entry.data.images.map((image) => (
						<img src={image.src} alt={image.alt} />
					))}
				</div>
			)}
			<div class="prose">
				<Content />
			</div>
		</div>
	</main>
	<ContactCTA />
</BaseLayout>

<style>
	main {
		padding-block: 3rem 5rem;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		max-width: 72rem;
	}

	.back-link {
		font-size: var(--text-sm);
		color: var(--text-muted);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.back-link:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.prompt {
		font-size: var(--text-sm);
		color: var(--text-dim);
		margin-bottom: 1.25rem;
	}

	.ps1 {
		color: var(--accent);
		font-weight: 600;
		margin-right: 0.5rem;
	}

	.meta {
		padding-left: 1.5rem;
		border-left: 2px solid var(--border);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.title {
		font-size: var(--text-2xl);
		color: var(--text);
		font-weight: 600;
	}

	.description {
		font-size: var(--text-base);
		color: var(--text-dim);
		line-height: 1.6;
		max-width: 60ch;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-size: var(--text-sm);
		color: var(--accent);
		background: var(--accent-subtle-overlay);
		border: 1px solid var(--accent-dim);
		padding: 0.2rem 0.6rem;
		border-radius: 2px;
	}

	.project-links {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.proj-link {
		font-size: var(--text-sm);
		padding: 0.4rem 1rem;
		text-decoration: none;
		border-radius: 2px;
		transition: background var(--theme-transition), color var(--theme-transition);
	}

	.proj-link--primary {
		background: var(--accent);
		color: var(--bg);
		border: 1px solid var(--accent);
	}

	.proj-link--primary:hover {
		background: var(--accent-light);
		border-color: var(--accent-light);
		text-decoration: none;
	}

	.proj-link--outline {
		background: transparent;
		color: var(--accent);
		border: 1px solid var(--accent-dim);
	}

	.proj-link--outline:hover {
		background: var(--accent-subtle-overlay);
		text-decoration: none;
	}

	.content {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.hero-img {
		width: 100%;
		max-height: 28rem;
		object-fit: cover;
		border: 1px solid var(--border);
	}

	.image-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		border: 1px solid var(--border);
	}

	.image-grid img {
		width: 100%;
		height: 18rem;
		object-fit: cover;
		object-position: top;
	}

	.image-grid img:last-child:nth-child(odd) {
		grid-column: span 2;
		height: 22rem;
	}

	/* Prose styles */
	.prose {
		max-width: 65ch;
		color: var(--text-dim);
		line-height: 1.7;
		font-size: var(--text-base);
	}

	.prose :global(* + *) {
		margin-top: 1rem;
	}

	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		color: var(--text);
		font-weight: 600;
		margin-top: 2rem;
		margin-bottom: 0.5rem;
	}

	.prose :global(h2) { font-size: var(--text-lg); }
	.prose :global(h3) { font-size: var(--text-base); }

	.prose :global(strong) {
		color: var(--text);
		font-weight: 600;
	}

	.prose :global(a) {
		color: var(--accent);
		text-decoration: none;
	}

	.prose :global(a:hover) {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-top: 0.4rem;
	}

	.prose :global(blockquote) {
		border-left: 2px solid var(--accent-dim);
		padding-left: 1rem;
		color: var(--text-dim);
		font-style: italic;
	}

	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--bg-elevated);
		padding: 0.1em 0.4em;
		border-radius: 2px;
		color: var(--accent);
	}

	.prose :global(pre) {
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		padding: 1rem 1.25rem;
		overflow-x: auto;
		border-radius: 2px;
	}

	.prose :global(pre code) {
		background: none;
		padding: 0;
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin-block: 2rem;
	}
</style>

---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Heng Xu" description="About Heng Xu — Software Engineer based in Orange County, CA">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. A bit about who I am and how I got here."
			/>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I'm a software engineer based in Orange County, CA with a background spanning information systems and computer science. I gravitate toward the full stack — designing APIs, wiring up databases, and building interfaces that feel good to use.
					</p>
					<p>
						Lately I've been deep in AI and agentic systems: building apps where LLMs autonomously call tools, stream responses, and adapt to user context. I find it genuinely exciting to close the gap between what models can do and what real users actually need.
					</p>
					<p>
						Outside of work, I surf whenever the swell cooperates (mostly San Onofre), snowboard in the winter, and am always somewhere on the hunt for a good wave or a good run.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>M.S. Computer Science — Northeastern University</p>
					<p>B.A. Information Systems — University of Washington</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p>Python · TypeScript · React · FastAPI · PostgreSQL · Claude API · Docker · Git</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>

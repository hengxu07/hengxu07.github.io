---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
---

<BaseLayout title="About | Heng Xu" description="About Heng Xu — Software Engineer based in Orange County, CA">
	<main class="wrapper">
		<p class="prompt"><span class="ps1">~/hengxu $</span> cat about.txt<span class="cursor"></span></p>

		<div class="sections">
			<section>
				<p class="section-label"><span class="comment">// </span>background</p>
				<div class="section-body">
					<p>
						Software engineer based in Orange County, CA. Background spanning information systems and computer science — I gravitate toward the full stack, from designing APIs to building interfaces that feel good to use.
					</p>
					<p>
						Lately I've been deep in AI and agentic systems: building apps where LLMs autonomously call tools, stream responses, and adapt to user context. I find it genuinely exciting to close the gap between what models can do and what real users actually need.
					</p>
					<p>
						Outside of work: surfing San Onofre when the swell shows up, snowboarding in the winter (Hakuba and Niseko are the dream), and studying Japanese — slow but getting there. I visit Japan as often as I can justify it.
					</p>
					<p>
						At home I'm kept in line by two cats — Kimchi and Onni. Also deep into anime; always have a few running at once.
					</p>
				</div>
			</section>

			<section>
				<p class="section-label"><span class="comment">// </span>education</p>
				<div class="section-body">
					<div class="edu-row">
						<span class="edu-degree">M.S. Computer Science</span>
						<span class="edu-school">Northeastern University</span>
					</div>
					<div class="edu-row">
						<span class="edu-degree">B.A. Information Systems</span>
						<span class="edu-school">University of Washington</span>
					</div>
				</div>
			</section>

			<section>
				<p class="section-label"><span class="comment">// </span>skills</p>
				<div class="section-body">
					<div class="skill-group">
						<span class="skill-category">languages</span>
						<span>Python · TypeScript · Swift · SQL</span>
					</div>
					<div class="skill-group">
						<span class="skill-category">backend</span>
						<span>FastAPI · PostgreSQL · Redis · Docker</span>
					</div>
					<div class="skill-group">
						<span class="skill-category">frontend</span>
						<span>React · Astro · SwiftUI</span>
					</div>
					<div class="skill-group">
						<span class="skill-category">ai / ml</span>
						<span>Claude API · LangGraph · tool-use · SSE streaming</span>
					</div>
				</div>
			</section>
		</div>
	</main>
	<ContactCTA />
</BaseLayout>

<style>
	main {
		padding-block: 4rem;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.prompt {
		font-size: var(--text-sm);
		color: var(--text-dim);
	}

	.ps1 {
		color: var(--accent);
		font-weight: 600;
		margin-right: 0.5rem;
	}

	.sections {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		padding-left: 1.5rem;
		border-left: 2px solid var(--border);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.section-label {
		font-size: var(--text-base);
		font-weight: 600;
		color: var(--text);
	}

	.comment {
		color: var(--text-muted);
	}

	.section-body {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		font-size: var(--text-sm);
		color: var(--text-dim);
		line-height: 1.7;
	}

	.edu-row {
		display: flex;
		gap: 1.5rem;
		align-items: baseline;
	}

	.edu-degree {
		color: var(--text);
		font-weight: 500;
		min-width: 18ch;
	}

	.edu-school {
		color: var(--text-dim);
	}

	.skill-group {
		display: flex;
		gap: 1.5rem;
		align-items: baseline;
	}

	.skill-category {
		color: var(--text-muted);
		min-width: 10ch;
		font-size: var(--text-sm);
	}

	@media (min-width: 50em) {
		.edu-row,
		.skill-group {
			gap: 2.5rem;
		}
	}
</style>

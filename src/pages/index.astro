---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ContactCTA from '../components/ContactCTA.astro';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout>
	<main class="wrapper">

		<!-- Hero -->
		<section class="hero">
			<div class="prompt-block">
				<p class="prompt"><span class="ps1">~/hengxu $</span> whoami</p>
				<div class="output">
					<p class="big">engineer. builder.</p>
					<p class="big dim">surfer. snowboarder. cat person.</p>
				</div>
				<p class="prompt"><span class="ps1">~/hengxu $</span> cat about.txt</p>
				<div class="output">
					<p class="tagline">
						most of my projects start with "I wish there was a tool that..." — so I build it.
					</p>
					<div class="tags">
						<span>python</span>
						<span>fastapi</span>
						<span>react</span>
						<span>claude api</span>
						<span>langgraph</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects -->
		<section class="projects">
			<div class="section-prompt">
				<p class="prompt"><span class="ps1">~/hengxu $</span> ls projects/</p>
			</div>
			<div class="project-grid">
				{projects.map((project) => (
					<PortfolioPreview project={project} />
				))}
			</div>
		</section>

		<!-- Skills -->
		<section class="skills">
			<p class="prompt"><span class="ps1">~/hengxu $</span> cat skills.txt</p>
			<div class="skills-grid">
				<div class="skill">
					<p class="skill-title"><span class="comment">// </span>full-stack</p>
					<p class="skill-body">Python · FastAPI · React · PostgreSQL<br/>ships the whole thing, database to deployed UI.</p>
				</div>
				<div class="skill">
					<p class="skill-title"><span class="comment">// </span>ai-powered</p>
					<p class="skill-body">Claude API · LangGraph · tool-use · SSE streaming<br/>agents that actually do useful work, not just wrappers.</p>
				</div>
				<div class="skill">
					<p class="skill-title"><span class="comment">// </span>product-minded</p>
					<p class="skill-body">thinks in user flows, not just endpoints.<br/>ships fast, iterates faster.</p>
				</div>
			</div>
		</section>

	</main>

	<ContactCTA />
</BaseLayout>

<style>
	main {
		padding-block: 4rem;
		display: flex;
		flex-direction: column;
		gap: 5rem;
	}

	/* ── Shared prompt style ── */
	.prompt {
		font-size: var(--text-sm);
		color: var(--text-dim);
		margin-bottom: 1rem;
	}

	.ps1 {
		color: var(--accent);
		font-weight: 600;
		margin-right: 0.5rem;
	}

	.output {
		padding-left: 1.5rem;
		border-left: 2px solid var(--border);
		margin-bottom: 2rem;
	}

	/* ── Hero ── */
	.hero {}

	.prompt-block {
		display: flex;
		flex-direction: column;
	}

	.big {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 600;
		line-height: 1.1;
		color: var(--text);
		letter-spacing: -0.03em;
	}

	.big.dim {
		color: var(--text-dim);
	}

	.tagline {
		font-size: var(--text-md);
		color: var(--text-dim);
		max-width: 55ch;
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tags span {
		font-size: var(--text-sm);
		color: var(--accent);
		background: var(--accent-subtle-overlay);
		border: 1px solid var(--accent-dim);
		padding: 0.2rem 0.6rem;
		border-radius: 2px;
	}

	/* ── Projects ── */
	.section-prompt {
		margin-bottom: 1.5rem;
	}

	.project-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1px;
		border: 1px solid var(--border);
	}

	@media (min-width: 50em) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* ── Skills ── */
	.skills-grid {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-left: 1.5rem;
		border-left: 2px solid var(--border);
		margin-top: 1rem;
	}

	.skill-title {
		font-size: var(--text-base);
		font-weight: 600;
		color: var(--text);
		margin-bottom: 0.25rem;
	}

	.comment {
		color: var(--text-muted);
	}

	.skill-body {
		font-size: var(--text-sm);
		color: var(--text-dim);
		line-height: 1.7;
	}

	@media (min-width: 50em) {
		.skills-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 3rem;
		}
	}
</style>

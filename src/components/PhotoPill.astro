---
interface Props {
	galleryId: string;
}
const { galleryId } = Astro.props;
---

<button class="pill" data-gallery-trigger={galleryId} aria-expanded="false">
	<slot />
</button>

<style>
	.pill {
		display: flex;
		align-items: center;
		padding: 0.5rem 1rem;
		gap: 0.5rem;
		color: var(--accent-text-over);
		border: 1px solid var(--accent-regular);
		background-color: var(--accent-regular);
		border-radius: 999rem;
		font-size: var(--text-md);
		line-height: 1.35;
		white-space: nowrap;
		cursor: pointer;
		font-family: inherit;
		transition:
			background-color 0.15s,
			border-color 0.15s;
	}

	.pill:hover,
	.pill[aria-expanded='true'] {
		background-color: var(--accent-dark);
		border-color: var(--accent-dark);
	}

	.pill:focus-visible {
		outline: 2px solid var(--accent-regular);
		outline-offset: 3px;
	}
</style>

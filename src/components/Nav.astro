---
const textLinks = [
	{ label: 'work', href: '/work/' },
	{ label: 'about', href: '/about/' },
];

const iconLinks = [
	{ label: 'github', href: 'https://github.com/hengxu07' },
	{ label: 'linkedin', href: 'https://www.linkedin.com/in/heng-xu-71603133' },
];

const isCurrentPage = (href: string) => {
	let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
	if (pathname.at(0) !== '/') pathname = '/' + pathname;
	if (pathname.at(-1) !== '/') pathname += '/';
	return pathname === href || (href !== '/' && pathname.startsWith(href));
};
---

<nav>
	<a href="/" class="site-title">~/hengxu</a>
	<div class="links">
		{textLinks.map(({ label, href }) => (
			<a
				href={href}
				class:list={['link', { active: isCurrentPage(href) }]}
				aria-current={isCurrentPage(href) ? 'page' : null}
			>
				{label}
			</a>
		))}
		<span class="divider">·</span>
		{iconLinks.map(({ label, href }) => (
			<a href={href} class="link external" target="_blank" rel="noopener noreferrer">
				{label}
			</a>
		))}
	</div>
</nav>

<style>
	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem;
		border-bottom: 1px solid var(--border);
		font-size: var(--text-sm);
	}

	.site-title {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.site-title:hover {
		text-decoration: none;
		opacity: 0.8;
	}

	.links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.link {
		color: var(--text-dim);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.link:hover {
		color: var(--text);
		text-decoration: none;
	}

	.link.active {
		color: var(--accent);
	}

	.divider {
		color: var(--border);
	}

	@media (min-width: 50em) {
		nav {
			padding: 1.5rem 2.5rem;
		}
	}
</style>

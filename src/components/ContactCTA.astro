<section class="contact wrapper">
	<p class="prompt"><span class="ps1">~/hengxu $</span> cat contact.txt</p>
	<div class="links">
		<a href="mailto:hengxu07@gmail.com" class="contact-link">
			<span class="label">email</span>
			<span class="value">hengxu07@gmail.com</span>
		</a>
		<a href="https://github.com/hengxu07" class="contact-link" target="_blank" rel="noopener noreferrer">
			<span class="label">github</span>
			<span class="value">github.com/hengxu07</span>
		</a>
		<a href="https://www.linkedin.com/in/heng-xu-71603133" class="contact-link" target="_blank" rel="noopener noreferrer">
			<span class="label">linkedin</span>
			<span class="value">linkedin.com/in/heng-xu-71603133</span>
		</a>
	</div>
</section>

<style>
	.contact {
		padding-block: 5rem;
		border-top: 1px solid var(--border);
		margin-top: auto;
	}

	.prompt {
		font-size: var(--text-sm);
		color: var(--text-dim);
		margin-bottom: 1.5rem;
	}

	.ps1 {
		color: var(--accent);
		font-weight: 600;
		margin-right: 0.5rem;
	}

	.links {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding-left: 1.5rem;
		border-left: 2px solid var(--border);
	}

	.contact-link {
		display: flex;
		align-items: baseline;
		gap: 1.5rem;
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.contact-link:hover {
		text-decoration: none;
	}

	.contact-link:hover .value {
		color: var(--accent);
	}

	.label {
		font-size: var(--text-sm);
		color: var(--text-muted);
		min-width: 6rem;
	}

	.value {
		font-size: var(--text-sm);
		color: var(--text-dim);
		transition: color var(--theme-transition);
	}
</style>

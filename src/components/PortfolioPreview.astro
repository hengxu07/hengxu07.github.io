---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;

const imgStyle = [
	data.img_position ? `object-position: ${data.img_position}` : '',
	data.img_fit ? `object-fit: ${data.img_fit}` : '',
].filter(Boolean).join('; ') || undefined;
---

<a class="card" href={`/work/${id}`}>
	<div class="img-wrap">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" style={imgStyle} />
	</div>
	<div class="info">
		<div class="title-row">
			<span class="arrow">▸</span>
			<span class="title">{data.title}</span>
		</div>
		<p class="description">{data.description}</p>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--bg);
		border-right: 1px solid var(--border);
		text-decoration: none;
		transition: background var(--theme-transition);
	}

	.card:hover {
		background: var(--bg-surface);
		text-decoration: none;
	}

	.img-wrap {
		height: 14rem;
		overflow: hidden;
		flex-shrink: 0;
		border-bottom: 1px solid var(--border);
		position: relative;
	}

	.img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: brightness(0.75);
		transition: transform 0.4s ease, filter 0.3s ease;
	}

	.card:hover .img-wrap img {
		transform: scale(1.02);
		filter: brightness(1);
	}

	.info {
		padding: 1.25rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.title-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.arrow {
		color: var(--accent);
		font-size: var(--text-sm);
	}

	.title {
		font-size: var(--text-base);
		font-weight: 600;
		color: var(--text);
	}

	.description {
		font-size: var(--text-sm);
		color: var(--text-dim);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin: 0;
		padding-left: 1.25rem;
	}

	@media (min-width: 50em) {
		.img-wrap {
			height: 16rem;
		}
	}
</style>

---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;

const imgStyle = [
	data.img_position ? `object-position: ${data.img_position}` : '',
	data.img_fit ? `object-fit: ${data.img_fit}` : '',
].filter(Boolean).join('; ') || undefined;
---

<a class="card" href={`/work/${id}`}>
	<div class="img-wrap">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" style={imgStyle} />
	</div>
	<div class="info">
		<span class="title">{data.title}</span>
		<p class="description">{data.description}</p>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		transition: box-shadow var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.img-wrap {
		height: 11rem;
		overflow: hidden;
		flex-shrink: 0;
	}

	.img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.info {
		padding: 1rem 1.25rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.title {
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--gray-200);
	}

	.description {
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.5;
		/* clamp to 2 lines */
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin: 0;
	}

	@media (min-width: 50em) {
		.card {
			border-radius: 1.5rem;
		}

		.img-wrap {
			height: 18rem;
		}

		.info {
			padding: 1.25rem 1.5rem 1.5rem;
		}
	}
</style>
